# =============================================================================
# Amira — environment variables. Copy to .env and fill in what you have.
# Only providers with a recurring free tier (no credit card required) are listed.
# Any provider with its key set is auto-enabled; the rest are silently skipped.
# =============================================================================

# ---------- Server ----------
PORT=3000
ALLOWED_ORIGIN=*
# Tunable rate limits (per-minute, per-IP; localhost is exempt)
# RATE_CHAT=120
# RATE_TRANSCRIBE=60
# RATE_TTS=120

# =============================================================================
# CHAT / LLM providers (fallback chain runs in this order)
# =============================================================================

# 1) Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyBWdL_U0g22UU3lBJxxPQhmI-80PmqtPqs
# GEMINI_MODEL=gemini-2.0-flash

# 2) Groq — https://console.groq.com/keys
GROQ_API_KEY=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
# GROQ_MODEL=llama-3.3-70b-versatile

# 3) OpenRouter (aggregator, many free models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=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
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# APP_URL=http://localhost:3000   # OpenRouter recommends an HTTP-Referer

# 4) Cerebras (very fast llama) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama-3.3-70b

# 5) Mistral (strong on French) — https://console.mistral.ai
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# 6) SambaNova (fast llama) — https://cloud.sambanova.ai
SAMBANOVA_API_KEY=
# SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# 7) GitHub Models (free dev tier) — https://github.com/marketplace/models
#    Create a fine-grained personal access token with the "Models: read" permission.
GITHUB_MODELS_TOKEN=
# GITHUB_MODELS_NAME=gpt-4o-mini

# 8) Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
# COHERE_MODEL=command-r-plus-08-2024

# =============================================================================
# STT / Speech-to-Text providers
# =============================================================================

# 1) Groq Whisper — uses GROQ_API_KEY above (whisper-large-v3-turbo)
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# 2) Cloudflare Workers AI (Whisper) — https://dash.cloudflare.com → AI → Workers AI
#    Account ID is shown in the right sidebar of the dashboard.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# =============================================================================
# TTS / Text-to-Speech providers
# =============================================================================

# 1) Groq Orpheus — uses GROQ_API_KEY (English + Arabic only)
# GROQ_TTS_VOICE_EN=hannah
# GROQ_TTS_VOICE_AR=aisha

# 2) ElevenLabs (10k chars/mo free, multilingual EN/FR/AR) — https://elevenlabs.io
#    Profile → API key. eleven_multilingual_v2 covers EN/FR/AR with one voice.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_MODEL=eleven_multilingual_v2

# 3) Cartesia (fast neural, EN + FR) — https://play.cartesia.ai
CARTESIA_API_KEY=
# CARTESIA_MODEL=sonic-2
# CARTESIA_VOICE_EN=79a125e8-cd45-4c13-8a67-188112f4dd22
# CARTESIA_VOICE_FR=65b25c5d-ff07-4687-a04c-da2f43ef6fa9
